@page
@model WebApp.Pages.CambiarContraseniaModel

@{
    Layout = null;
    ViewData["Title"] = "Cambiar Contraseña";
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alpha Energy</title>
    <link rel="stylesheet" href="~/css/cambiarcontrasenia.css" />
    <link rel="stylesheet" href="~/css/signicono.css" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/ControlActions.js"></script>
</head>



<header class="app-header">
    <div class="logo-mark">ALPHA <span>ENERGY</span></div>
    <a href="/Login" class="btn-login-youtube">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.8" />
            <circle cx="16" cy="11" r="4.5" stroke="currentColor" stroke-width="1.8" />
            <path d="M6 26C6 22 10 19 16 19C22 19 26 22 26 26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
        <span>Iniciar sesión</span>
    </a>
</header>

<!-- ===== CONTENIDO ===== -->
<main class="cambiar-contrasenia-content">

    <div class="cambiar-contrasenia-card">

        <div class="cambiar-contrasenia-header">
            <div class="icono-candado">🔒</div>
            <h1 class="cambiar-contrasenia-title">Cambiar contraseña</h1>
            <p class="cambiar-contrasenia-desc" id="descPaso">Ingresa tu correo electrónico para recibir un código de verificación</p>
        </div>

        <!-- ===== PASO 1: SOLICITAR CÓDIGO ===== -->
        <form id="formSolicitar" class="cambiar-contrasenia-form">

            <div class="form-group">
                <label class="field-label">Correo electrónico <span class="required">*</span></label>
                <div class="input-container">
                    <input type="email" id="txtCorreo" class="field-input" placeholder="Correo electrónico" />
                </div>
            </div>

            <div class="buttons-row">
                <button id="btnEnviarCodigo" type="submit" class="btn-primary">Enviar código</button>
                <a href="/Login" class="btn-secondary">Cancelar</a>
            </div>

        </form>

        <!-- ===== PASO 2: CÓDIGO OTP + NUEVA CONTRASEÑA ===== -->
        <form id="formCambiar" class="cambiar-contrasenia-form" style="display:none;">

            <div class="form-group">
                <label class="field-label">Código de verificación <span class="required">*</span></label>
                <div class="input-container">
                    <input type="text" id="txtOtp" maxlength="6" class="field-input" placeholder="Ingresa el código de 6 dígitos" />
                </div>
                <div class="field-hint">El código expira en 5 minutos</div>
            </div>

            <!-- Nueva contraseña -->
            <div class="form-group">
                <label class="field-label">Nueva contraseña <span class="required">*</span></label>
                <div class="input-container">
                    <input type="password" id="txtNuevaContrasena" class="field-input" placeholder="Cree una nueva contraseña" />
                    <button type="button" class="toggle-password" onclick="togglePassword(this)">👁️</button>
                </div>
                <div class="field-hint">Mínimo 8 caracteres, incluye mayúscula, minúscula y número</div>
            </div>

            <!-- Confirmar nueva contraseña -->
            <div class="form-group">
                <label class="field-label">Confirmar nueva contraseña <span class="required">*</span></label>
                <div class="input-container">
                    <input type="password" id="txtConfirmarContrasena" class="field-input" placeholder="Repita la nueva contraseña" />
                    <button type="button" class="toggle-password" onclick="togglePassword(this)">👁️</button>
                </div>
            </div>

            <!-- ===== REQUISITOS DE CONTRASEÑA ===== -->
            <div class="requisitos-contrasenia">
                <p class="requisitos-titulo">La contraseña debe cumplir con:</p>
                <ul class="requisitos-lista">
                    <li id="req-longitud">✅ Al menos 8 caracteres</li>
                    <li id="req-mayuscula">✅ Al menos una mayúscula</li>
                    <li id="req-minuscula">✅ Al menos una minúscula</li>
                    <li id="req-numero">✅ Al menos un número</li>
                </ul>
            </div>

            <!-- ===== BOTONES ===== -->
            <div class="buttons-row">
                <button id="btnCambiarContrasena" type="submit" class="btn-primary">Cambiar contraseña</button>
                <a href="/Login" class="btn-secondary">Cancelar</a>
            </div>

            <div style="text-align:center; margin-top:10px;">
                <button type="button" id="btnReenviarCodigo" class="btn-ghost" style="font-size:10px;">Reenviar código</button>
            </div>

        </form>

    </div>

</main>

<!-- ===== FOOTER ===== -->
<footer class="wf-footer">
    <p>&copy; 2026 Alpha Energy. Todos los derechos reservados.</p>
</footer>

<script>
    // ===== MOSTRAR/OCULTAR CONTRASEÑA =====
    function togglePassword(btn) {
        const input = btn.parentElement.querySelector('.field-input');
        if (input.type === 'password') {
            input.type = 'text';
            btn.textContent = '🙈';
        } else {
            input.type = 'password';
            btn.textContent = '👁️';
        }
    }

    // ===== VALIDACIÓN DE CONTRASEÑA EN TIEMPO REAL =====
    document.getElementById('formCambiar').addEventListener('input', function (e) {
        const pass = document.getElementById('txtNuevaContrasena').value;

        const reqLongitud = document.getElementById('req-longitud');
        const reqMayuscula = document.getElementById('req-mayuscula');
        const reqMinuscula = document.getElementById('req-minuscula');
        const reqNumero = document.getElementById('req-numero');

        if (pass.length >= 8) {
            reqLongitud.textContent = '✅ Al menos 8 caracteres';
            reqLongitud.style.color = '#10b981';
        } else {
            reqLongitud.textContent = '❌ Al menos 8 caracteres';
            reqLongitud.style.color = '#ef4444';
        }

        if (/[A-Z]/.test(pass)) {
            reqMayuscula.textContent = '✅ Al menos una mayúscula';
            reqMayuscula.style.color = '#10b981';
        } else {
            reqMayuscula.textContent = '❌ Al menos una mayúscula';
            reqMayuscula.style.color = '#ef4444';
        }

        if (/[a-z]/.test(pass)) {
            reqMinuscula.textContent = '✅ Al menos una minúscula';
            reqMinuscula.style.color = '#10b981';
        } else {
            reqMinuscula.textContent = '❌ Al menos una minúscula';
            reqMinuscula.style.color = '#ef4444';
        }

        if (/[0-9]/.test(pass)) {
            reqNumero.textContent = '✅ Al menos un número';
            reqNumero.style.color = '#10b981';
        } else {
            reqNumero.textContent = '❌ Al menos un número';
            reqNumero.style.color = '#ef4444';
        }
    });
</script>

<script src="~/js/pages-controllers/CambiarContraseniaViewController.js"></script>