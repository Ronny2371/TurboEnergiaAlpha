@page
@model WebApp.Pages.PortalDistribuidorModel

@{
    Layout = null;
    ViewData["Title"] = "Portal Distribuidor";
}

<link rel="stylesheet" href="~/css/paneladministrador.css" />
<link rel="stylesheet" href="~/css/cerrarsesion.css" />
<link rel="stylesheet" href="~/css/portaldistribuidor.css" />

<div class="dashboard-container">

    <!-- ===== HEADER ===== -->
    <header class="app-header">
        <div class="logo-mark">ALPHA <span>ENERGY</span></div>
        <div class="user-chip">
            <div class="avatar-circle">DS</div>
            <div>
                <div class="user-name">Distribuidora del Sur S.A.</div>
                <div class="user-role">Distribuidor</div>
            </div>
        </div>
    </header>

    <!-- ===== LAYOUT (sidebar + contenido) ===== -->
    <div class="app-layout">

        <!-- ===== sidebar ===== -->
        <nav class="app-sidebar">
            <div class="s-label">Menu</div>
            <a class="s-item" asp-page="/PanelAdministrador">Dashboard</a>
            <a class="s-item" asp-page="/RegistroDeUsuario">Usuarios</a>
            <a class="s-item" asp-page="/GestionDeTurbinas">Turbinas</a>
            <a class="s-item" asp-page="/RegistroDeMantenimiento">Mantenimiento</a>
            <a class="s-item active" asp-page="/PortalDistribuidor">Distribución</a>
            <a class="s-item" asp-page="/ReporteDeFacturacion">Reportes</a>
            <a class="s-item" asp-page="/Auditoria">Auditoría</a>
            <a class="s-item logout" href="/Login">Cerrar sesión</a>
        </nav>

        <!-- ===== CONTENIDO ===== -->
        <main class="app-content">

            <div class="distribuidor-card">

                <div class="distribuidor-header">
                    <h1 class="distribuidor-title">Mis Solicitudes de Compra</h1>
                    <p class="distribuidor-desc">Gestione sus solicitudes de energía para el año 2026</p>
                </div>

                <div class="page-title-row">
                    <div></div>
                    <button class="btn-primary">+ Nueva Solicitud</button>
                </div>

                <!-- ===== INFO CARD ===== -->
                <div class="info-card">
                    <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
                        <circle cx="8" cy="8" r="7" stroke="#2563eb" stroke-width="1.5" />
                        <path d="M8 7v4M8 5v1" stroke="#2563eb" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    <span>Puede registrar un máximo de <strong>6</strong> solicitudes activas por año. Actualmente tiene <strong>3</strong> activas.</span>
                </div>

                <!-- ===== TABLA ===== -->
                <table class="wf-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Mes / Año</th>
                            <th>Cantidad Solicitada</th>
                            <th>Estado</th>
                            <th>Fecha Solicitud</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td style="color:#9ca3af;font-size:12px;">001</td>
                            <td><strong>08 / 2026</strong></td>
                            <td>120 MWh</td>
                            <td>
                                <span class="badge badge-yellow">
                                    <span class="badge-dot badge-dot-yellow"></span>
                                    Pendiente
                                </span>
                            </td>
                            <td style="font-size:12px;color:#6b7280;">02/07/2026</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn view">👁 Ver</button>
                                    <button class="action-btn cancel">✕ Anular</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td style="color:#9ca3af;font-size:12px;">002</td>
                            <td><strong>09 / 2026</strong></td>
                            <td>100 MWh</td>
                            <td>
                                <span class="badge badge-yellow">
                                    <span class="badge-dot badge-dot-yellow"></span>
                                    Pendiente
                                </span>
                            </td>
                            <td style="font-size:12px;color:#6b7280;">05/07/2026</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn view">👁 Ver</button>
                                    <button class="action-btn cancel">✕ Anular</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td style="color:#9ca3af;font-size:12px;">003</td>
                            <td><strong>10 / 2026</strong></td>
                            <td>150 MWh</td>
                            <td>
                                <span class="badge badge-green">
                                    <span class="badge-dot badge-dot-green"></span>
                                    Aprobada
                                </span>
                            </td>
                            <td style="font-size:12px;color:#6b7280;">10/07/2026</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn view">👁 Ver</button>
                                    <span class="action-disabled">---</span>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td style="color:#9ca3af;font-size:12px;">004</td>
                            <td><strong>11 / 2026</strong></td>
                            <td>80 MWh</td>
                            <td>
                                <span class="badge badge-yellow">
                                    <span class="badge-dot badge-dot-yellow"></span>
                                    Pendiente
                                </span>
                            </td>
                            <td style="font-size:12px;color:#6b7280;">15/07/2026</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn view">👁 Ver</button>
                                    <button class="action-btn cancel">✕ Anular</button>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <td style="color:#9ca3af;font-size:12px;">005</td>
                            <td><strong>12 / 2026</strong></td>
                            <td>200 MWh</td>
                            <td>
                                <span class="badge badge-green">
                                    <span class="badge-dot badge-dot-green"></span>
                                    Aprobada
                                </span>
                            </td>
                            <td style="font-size:12px;color:#6b7280;">20/07/2026</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="action-btn view">👁 Ver</button>
                                    <span class="action-disabled">---</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- ===== MAX NOTE ===== -->
                <div class="max-note">
                    (máx. 6 solicitudes activas por año — <strong>1</strong> espacio disponible)
                </div>

                <!-- ===== ANNOTATION ===== -->
                <div class="annotation-section">
                    <span class="ann">Estado "Pendiente" requiere aprobación del administrador</span>
                </div>

                <!-- ===== PAGINACIÓN ===== -->
                <div class="pagination-row">
                    <span class="pagination-info">5 de 5 solicitudes</span>
                    <div class="pagination-buttons">
                        <button class="page-btn">‹</button>
                        <button class="page-btn active">1</button>
                        <button class="page-btn">›</button>
                    </div>
                </div>

            </div>

        </main>

    </div>

    <!-- ===== FOOTER ===== -->
    <footer class="wf-footer">
        <p>&copy; 2026 Alpha Energy. Todos los derechos reservados.</p>
    </footer>

</div>