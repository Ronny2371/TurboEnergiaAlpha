<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alpha Energy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/signicono.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ===== HEADER ESTILO ALPHA ENERGY ===== -->
    <header class="app-header">
        <div class="logo-mark">ALPHA <span>ENERGY</span></div>

        <!-- Menú de navegación con TODOS los enlaces -->
        <nav class="nav-menu">
            <ul class="nav-list">
                <li class="nav-item">
                    <a class="nav-link" asp-page="/RegistroDeUsuario">Registro de Usuario</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-page="/Login">Login</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-page="/PanelAdministrador">Panel Administrador</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-page="/GestionDeTurbinas">Gestión de Turbinas</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-page="/RegistroDeMantenimiento">Registro de Mantenimiento</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-page="/PortalDistribuidor">Portal Distribuidor</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-page="/ReporteDeFacturacion">Reporte de Facturación</a>
                </li>
            </ul>
        </nav>

        <!-- Botón Login -->
        <a href="/Login" class="btn-login-youtube">
            <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.8" />
                <circle cx="16" cy="11" r="4.5" stroke="currentColor" stroke-width="1.8" />
                <path d="M6 26C6 22 10 19 16 19C22 19 26 22 26 26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
            </svg>
            <span>Iniciar sesión</span>
        </a>
    </header>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="wf-footer">
        <p>&copy; 2026 Alpha Energy. Todos los derechos reservados.</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>