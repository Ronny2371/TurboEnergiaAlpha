<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Alpha Energy</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApp.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/signicono.css" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <link href="https://cdn.datatables.net/2.3.8/css/dataTables.dataTables.min.css" rel="stylesheet" />
    <script src="https://cdn.datatables.net/2.3.8/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/ControlActions.js"></script>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ===== HEADER CON MENÚ HORIZONTAL ===== -->
    <header class="app-header">

        <!-- Logo siempre visible -->
        <a asp-page="/LandingPageAlfaEnergy" style="text-decoration: none"><div class="logo-mark">ALPHA <span>ENERGY</span></div></a>

        @{
            var usuarioAutenticado = false;
        }

        @if (usuarioAutenticado)
        {
            <!-- ===== MENÚ HORIZONTAL COMPLETO (SOLO SI HA INICIADO SESIÓN) ===== -->
            <nav class="nav-menu-horizontal">
                <ul class="nav-list-horizontal">
                    <li><a class="nav-link-horizontal" asp-page="/PanelAdministrador">Dashboard</a></li>
                    <li><a class="nav-link-horizontal" asp-page="/RegistroDeUsuario">Usuarios</a></li>
                    <li><a class="nav-link-horizontal" asp-page="/GestionDeTurbinas">Turbinas</a></li>
                    <li><a class="nav-link-horizontal" asp-page="/RegistroDeMantenimiento">Mantenimiento</a></li>
                    <li><a class="nav-link-horizontal" asp-page="/PortalDistribuidor">Distribución</a></li>
                    <li><a class="nav-link-horizontal" asp-page="/ReporteDeFacturacion">Reportes</a></li>
                    <li><a class="nav-link-horizontal" asp-page="/Auditoria">Auditoría</a></li>
                </ul>
            </nav>

            <!-- Botón de cerrar sesión -->
            <a href="/Login" class="btn-logout">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
                Cerrar sesión
            </a>
        }
        else
        {
            <!-- ===== BOTONES DE ACCESO (SOLO SI NO HA INICIADO SESIÓN) ===== -->
            <div class="auth-buttons">
                <a href="/RegistroDeUsuario" class="btn-register">Registrarse</a>
                <a href="/Login" class="btn-login-youtube">
                    <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="16" cy="16" r="15" stroke="currentColor" stroke-width="1.8" />
                        <circle cx="16" cy="11" r="4.5" stroke="currentColor" stroke-width="1.8" />
                        <path d="M6 26C6 22 10 19 16 19C22 19 26 22 26 26" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                    <span>Iniciar sesión</span>
                </a>
            </div>
        }

    </header>

    <!-- ===== CONTENIDO PRINCIPAL ===== -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="wf-footer">
        <p>&copy; 2026 Alpha Energy. Todos los derechos reservados.</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>