@page
@model WebApp.Pages.ReporteDeFacturacionModel

@{
    Layout = null;
    ViewData["Title"] = "Reporte de Facturación";
}

<link rel="stylesheet" href="~/css/reportedefacturacion.css" />

<div class="facturacion-container">

    <!-- ===== HEADER ===== -->
    <header class="app-header">
        <div class="logo-mark">ALPHA <span>ENERGY</span></div>
        <div class="user-chip">
            <div class="avatar-circle">DS</div>
            <div>
                <div class="user-name">Distribuidora del Sur S.A.</div>
                <div class="user-role">Distribuidor</div>
            </div>
        </div>
    </header>

    <!-- ===== CONTENIDO ===== -->
    <main class="facturacion-content-full">

        <div class="facturacion-card">

            <div class="facturacion-header">
                <h1 class="facturacion-title">Reporte de Distribución</h1>
                <p class="facturacion-desc">Resumen financiero del período facturado</p>
            </div>

            <!-- ===== BOTONES DE ACCIÓN ===== -->
            <div class="action-bar">
                <button class="btn-outline btn-pdf">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <path d="M8 1v9M4 6l4 4 4-4" stroke="#555" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        <path d="M2 12h12" stroke="#555" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                    Descargar PDF
                </button>
                <button class="btn-outline btn-print">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                        <rect x="2" y="4" width="12" height="10" rx="1" stroke="#555" stroke-width="1.4" />
                        <path d="M5 4V3a1 1 0 011-1h4a1 1 0 011 1v1" stroke="#555" stroke-width="1.4" />
                        <path d="M5 9h6M5 12h4" stroke="#555" stroke-width="1.3" stroke-linecap="round" />
                    </svg>
                    Imprimir
                </button>
            </div>

            <!-- ===== PERIOD HEADER CARD ===== -->
            <div class="report-header-card">
                <div>
                    <div class="report-period">Julio 2026</div>
                    <div class="report-period-sub">Período de facturación — Cerrado</div>
                </div>
                <div class="report-meta">
                    <div class="meta-item">
                        <span class="meta-label">Distribuidor</span>
                        <span class="meta-value">Distribuidora del Sur S.A.</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">No. Factura</span>
                        <span class="meta-value code">AE-2026-0074</span>
                    </div>
                    <div class="meta-item">
                        <span class="meta-label">Estado</span>
                        <span class="badge badge-blue">
                            <span class="badge-dot badge-dot-blue"></span>
                            Emitida
                        </span>
                    </div>
                </div>
            </div>

            <!-- ===== GRID ===== -->
            <div class="report-grid">

                <!-- ===== INVOICE BREAKDOWN ===== -->
                <div class="invoice-card">
                    <div class="invoice-title">Desglose de Cobros</div>

                    <div class="invoice-row">
                        <span class="lbl">Energía Asignada</span>
                        <span class="val">120 MWh</span>
                    </div>
                    <div class="invoice-row">
                        <span class="lbl">Precio por MWh</span>
                        <span class="val">$ 145.50</span>
                    </div>
                    <div class="invoice-row subtotal">
                        <span class="lbl">Subtotal</span>
                        <span class="val">$ 17,460.00</span>
                    </div>
                    <div class="invoice-row">
                        <span class="lbl">Impuesto (13%)</span>
                        <span class="val tax">$ 2,269.80</span>
                    </div>

                    <div class="invoice-total">
                        <span>Total a Pagar</span>
                        <span>$ 19,729.80</span>
                    </div>

                    <div class="invoice-note">
                        <span class="ann">Precios definidos por administrador al aprobar solicitud</span>
                    </div>
                </div>

                <!-- ===== CONSUMPTION DETAIL ===== -->
                <div>
                    <div class="chart-card">
                        <div class="chart-title">Consumo vs Asignado — Julio 2026</div>
                        <svg viewBox="0 0 280 110" width="100%" style="display:block;">
                            <line x1="40" y1="10" x2="40" y2="80" stroke="#e5e7eb" stroke-width="1" />
                            <line x1="40" y1="80" x2="270" y2="80" stroke="#e5e7eb" stroke-width="1" />
                            <line x1="40" y1="10" x2="270" y2="10" stroke="#f3f4f6" stroke-width="1" />
                            <line x1="40" y1="45" x2="270" y2="45" stroke="#f3f4f6" stroke-width="1" />
                            <text x="35" y="13" text-anchor="end" font-size="8" fill="#9ca3af">150</text>
                            <text x="35" y="48" text-anchor="end" font-size="8" fill="#9ca3af">75</text>
                            <text x="35" y="83" text-anchor="end" font-size="8" fill="#9ca3af">0</text>
                            <rect x="80" y="14" width="50" height="66" fill="#d1d5db" rx="3" />
                            <text x="105" y="95" text-anchor="middle" font-size="8" fill="#9ca3af">Asignado</text>
                            <text x="105" y="9" text-anchor="middle" font-size="8" fill="#555" font-weight="700">120</text>
                            <rect x="180" y="22" width="50" height="58" fill="#111" rx="3" />
                            <text x="205" y="95" text-anchor="middle" font-size="8" fill="#9ca3af">Consumido</text>
                            <text x="205" y="17" text-anchor="middle" font-size="8" fill="#555" font-weight="700">105</text>
                        </svg>
                        <div class="chart-note">[Gráfico de barras — Asignado vs Consumido en MWh]</div>
                    </div>

                    <div class="notes-card">
                        <div class="notes-title">Notas del Período</div>
                        <div class="notes-list">
                            <div class="note-item">
                                <span class="note-icon check">✓</span>
                                Solicitud aprobada el 25/06/2026
                            </div>
                            <div class="note-item">
                                <span class="note-icon check">✓</span>
                                Energía entregada dentro del período
                            </div>
                            <div class="note-item">
                                <span class="note-icon warning">!</span>
                                15 MWh no consumidos — sin penalización
                            </div>
                        </div>
                    </div>
                </div>

            </div>

        </div>

    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="wf-footer">
        <p>&copy; 2026 Alpha Energy. Todos los derechos reservados.</p>
    </footer>

</div>